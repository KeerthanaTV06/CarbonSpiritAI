# Carbon Spirit Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Required ──────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────
PORT=5000
FLASK_DEBUG=true
